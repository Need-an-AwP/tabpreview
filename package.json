{
  "name": "tabpreview",
  "displayName": "TabPreview",
  "description": "Custom tab switcher with previews",
  "version": "0.0.6",
  "publisher": "NeedanAwP",
  "license": "MIT",
  "preview": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Need-an-AwP/tabpreview"
  },
  "icon": "./asserts/icon.png",
  "homepage": "https://github.com/Need-an-AwP/tabpreview#readme",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "tab",
    "tabs",
    "tab switcher",
    "tab preview",
    "editor",
    "navigation",
    "ctrl+tab"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "TabPreview",
      "properties": {
        "tabPreview.retainWebview": {
          "type": "boolean",
          "default": true,
          "description": "Keep the webview alive or dispose it asap\nATTENTION: Retaining the WebView reduces performance overhead and significantly accelerates response times."
        },
        "tabPreview.size": {
          "type": "number",
          "default": 90,
          "minimum": 0,
          "description": "The size of tab items in pixels"
        },
        "tabPreview.icon.display": {
          "type": "boolean",
          "default": true,
          "description": "Display icon"
        },
        "tabPreview.icon.grayscale": {
          "type": "boolean",
          "default": false,
          "description": "Grayscale icon"
        },
        "tabPreview.icon.opacity": {
          "type": "number",
          "default": 0.6,
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity of icons, range: 0 to 1"
        },
        "tabPreview.icon.size": {
          "type": "number",
          "default": 45,
          "description": "Size in px"
        },
        "tabPreview.icon.position": {
          "type": "string",
          "default": "center",
          "description": "Icon position",
          "enum": [
            "top",
            "center",
            "bottom",
            "top-left",
            "top-right",
            "center-left",
            "center-right",
            "bottom-left",
            "bottom-right"
          ]
        },
        "tabPreview.showCloseButton": {
          "type": "boolean",
          "default": true,
          "description": "Whether to show close buttons on tab items"
        },
        "tabPreview.thumbnail.display": {
          "type": "boolean",
          "default": true,
          "description": "Whether to show thumbnails in the tab switcher"
        },
        "tabPreview.thumbnail.theme": {
          "type": "string",
          "default": "vs-dark",
          "description": "Theme of editor thumbnails",
          "enum": [
            "vs",
            "vs-dark",
            "hc-black",
            "hc-light"
          ]
        },
        "tabPreview.thumbnail.fontSize": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "description": "Editor thumbnail font size in px"
        },
        "tabPreview.thumbnail.lineHeight": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "description": "Editor thumbnail line height in px"
        },
        "tabPreview.thumbnail.renderCharacters": {
          "type": "boolean",
          "default": false,
          "description": "Display characters or color blocks in thumbnails"
        },
        "tabPreview.thumbnail.opacity": {
          "type": "number",
          "default": 0.4,
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity of editor thumbnails, range: 0 to 1"
        },
        "tabPreview.thumbnail.onlyVisibleRange": {
          "type": "boolean",
          "default": true,
          "description": "Only get text from editors' visible range\n!!! CAUTION: DISABLE THIS MIGHT AFFECT PERFORMANCE !!!"
        }
      }
    },
    "commands": [
      {
        "command": "tabpreview.showSwitcher",
        "title": "Show Tab Switcher Panel",
        "category": "TabPreview"
      },
      {
        "command": "tabpreview.selectNext",
        "title": "Select Next Tab",
        "category": "TabPreview"
      },
      {
        "command": "tabpreview.selectPrevious",
        "title": "Select Previous Tab",
        "category": "TabPreview"
      },
      {
        "command": "tabpreview.settings",
        "title": "Open TabPreview Settings",
        "category": "TabPreview"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tabpreview.showSwitcher",
          "when": "false"
        },
        {
          "command": "tabpreview.selectNext",
          "when": "false"
        },
        {
          "command": "tabpreview.selectPrevious",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tabpreview.showSwitcher",
        "key": "ctrl+tab"
      },
      {
        "command": "tabpreview.selectNext",
        "key": "ctrl+tab",
        "when": "tabpreview.visible"
      },
      {
        "command": "tabpreview.selectNext",
        "key": "ctrl+right",
        "when": "tabpreview.visible"
      },
      {
        "command": "tabpreview.selectPrevious",
        "key": "ctrl+left",
        "when": "tabpreview.visible"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "vscode:prepublish": "npm run webview:build && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "webview:watch": "npm -C src/webview run watch",
    "webview:build": "npm -C src/webview run build",
    "webview:dev": "npm -C src/webview run dev"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "lit-html": "^3.3.2"
  }
}