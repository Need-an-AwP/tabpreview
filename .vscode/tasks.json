// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "webview:build",
			"type": "npm",
			"script": "webview:build", // run build of the sub vite project
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"type": "npm",
			"script": "compile", // "watch" is replaced by "compile"
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"webview:build" // ensure webview is built before starting watch
			]
		}
	]
}
